{
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "fs:default",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-exists",
    "dialog:default",
    "dialog:allow-save",
    "dialog:allow-open",
    "shell:allow-open",
    "process:default",
    "process:allow-exit"
  ]
}
