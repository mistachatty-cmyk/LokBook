# LokBook Environment Variables Reference
# Copy relevant values to .env.local (gitignored) for local dev.
# All credentials are stored in .env.local — keep it safe, never commit.

# ---- App (Vite client-side vars) ----
# Used by src/supabaseClient.js at build time.
# Get these from: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://jfavkudihasswkhkouxq.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=<anon/public key>

# ---- Supabase CLI (migrations) ----
# Get SUPABASE_ACCESS_TOKEN from: https://supabase.com/dashboard/account/tokens
# Get SUPABASE_DB_PASSWORD from: Supabase Dashboard → Project Settings → Database
SUPABASE_ACCESS_TOKEN=<access token>
SUPABASE_DB_PASSWORD=<database password>

# ---- Stripe (LokPass payments) ----
# Get from: https://dashboard.stripe.com/test/apikeys
# VITE_STRIPE_PK is in src/constants.jsx — rotate if compromised
# VITE_STRIPE_PK=<stripe publishable key>

# ---- Wrangler / Cloudflare (optional) ----
# CLOUDFLARE_API_TOKEN=<token>
# CLOUDFLARE_ACCOUNT_ID=<account id>
